# Netlify / local tooling — NEVER commit real secrets
#
# Client Firebase (required for Netlify build + local npm start)
FIREBASE_WEB_API_KEY=
# Optional overrides (defaults match project avelon-wealth)
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_APP_ID=
# FIREBASE_MEASUREMENT_ID=

PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=

# --- Firebase Admin (Netlify functions) ---
# On Netlify: do NOT set FIREBASE_SERVICE_ACCOUNT_JSON — the full JSON pushes total env size
# over AWS Lambda’s ~4KB limit and every function deploy fails. Use these three instead
# (from the same service account JSON in Firebase Console → Project settings → Service accounts):
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key PEM as one line with \n for newlines, OR put base64 in FIREBASE_PRIVATE_KEY_B64
FIREBASE_PRIVATE_KEY=
# FIREBASE_PRIVATE_KEY_B64=
#
# Local / CI only (optional): whole JSON file as a single line — avoid on Netlify.
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Operator login for /.netlify/functions/adminCustomToken (must match what you type on login)
ADMIN_OPERATOR_PASSWORD=

# Optional — Netlify frontend canonical URL (also set on Render as PUBLIC_SITE_URL for checkout return URLs)
PUBLIC_SITE_URL=https://avelonwealth.site

# --- Netlify build: point the browser to Render API ---
# Example: https://avelon-api.onrender.com/api
AVELON_FUNCTIONS_BASE=
# Alias accepted by inject script:
# RENDER_API_URL=

# --- Render service only: must match Netlify site origin (https) for PayMongo success/cancel URLs ---
# PUBLIC_SITE_URL=https://avelonwealth.site
# Optional extra allowed origins (comma-separated) if you use multiple frontend domains:
# ALLOWED_PUBLIC_ORIGINS=https://avelonwealth.site,https://www.avelonwealth.site
